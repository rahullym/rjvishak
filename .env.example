MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/rjvishakh?retryWrites=true&w=majority
AUTH_SECRET=replace-with-openssl-rand-base64-32
ADMIN_EMAIL=admin@rjvisakh.com
ADMIN_PASSWORD=replace-with-a-strong-password
PUBLIC_CORS_ORIGIN=https://www.rjvisakh.com

# AWS S3 — used by /api/admin/upload for editor image uploads.
# The IAM key needs s3:PutObject on the bucket. The bucket must allow public
# read on uploaded objects (via bucket policy or ACL).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=rj-visakh
# Optional: serve uploads through CloudFront/CDN. Leave empty to use the direct S3 URL.
AWS_S3_PUBLIC_URL=
